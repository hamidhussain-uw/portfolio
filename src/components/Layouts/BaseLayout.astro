---
import '../../styles/global.css';
import Navbar from '../Sections/Navbar.astro';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Portfolio — QA Engineer',
	description = 'QA Automation & Manual Testing — portfolios, case studies, and contact.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Syne:wght@500;600;700;800&display=swap"
			rel="stylesheet"
		/>
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body class="min-h-screen antialiased">
		<div class="ambient-glow ambient-glow--one" aria-hidden="true"></div>
		<div class="ambient-glow ambient-glow--two" aria-hidden="true"></div>
		<div id="top" class="relative z-10 flex min-h-screen flex-col">
			<Navbar />
			<slot />
		</div>
	</body>
</html>
